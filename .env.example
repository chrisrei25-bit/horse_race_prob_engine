# Copy this file to .env and fill in values. Never commit .env to version control.

# Data source credentials (fill in when data layer is implemented)
# RACING_POST_EMAIL=
# RACING_POST_AUTH_STATE=
# RACING_POST_ACCESS_TOKEN=

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Data paths (override defaults in configs/base.yaml if needed)
# RAW_DATA_DIR=data/raw
# PROCESSED_DATA_DIR=data/processed
